{
  "name": "interview-prep-preview",
  "version": "1.0.0",
  "description": "NestJS preview server for interview preparation markdown files",
  "scripts": {
    "start": "node node_modules/ts-node/dist/bin.js -r tsconfig-paths/register src/main.ts",
    "start:dev": "node node_modules/nodemon/bin/nodemon.js",
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.json",
    "start:prod": "node dist/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
